{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "neo": {
      "source": {
        "source": "github",
        "repo": "psumiya/neo",
        "ref": "v0"
      }
    }
  },
  "enabledPlugins": {
    "core-workflow@neo": true,
    "risk-review@neo": true,
    "evals@neo": true
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/secrets/**)"
    ]
  }
}
